{
  "version": 2,
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "index.py", "use": "@vercel/python" }
  ],
  "rewrites": [
    { "source": "/api/hunter", "destination": "/api/hunter.py" },
    { "source": "/api/scrubber", "destination": "/api/scrubber.py" },
    { "source": "/api/enricher", "destination": "/api/enricher.py" },
    { "source": "/api/architect", "destination": "/api/architect.py" },
    { "source": "/(.*)", "destination": "/index.py" }
  ]
}
